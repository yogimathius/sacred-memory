{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MemoryItem",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "scope": { "type": "string", "enum": ["global", "repo", "branch", "task"] },
    "tool": { "type": "string" },
    "kind": { "type": "string", "enum": ["preference", "convention", "task_state", "summary", "fact", "canon", "candidate"] },
    "content": { "type": ["string", "object"] },
    "tags": { "type": "array", "items": { "type": "string" } },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "pinned": { "type": "boolean" },
    "created_at": { "type": "string", "format": "date-time" },
    "last_used_at": { "type": ["string", "null"], "format": "date-time" },
    "expires_at": { "type": ["string", "null"], "format": "date-time" },
    "source_session_id": { "type": ["string", "null"] }
  },
  "required": ["id", "scope", "kind", "content", "created_at"],
  "additionalProperties": true
}