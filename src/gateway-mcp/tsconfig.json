{
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",
    "module": "node16",
    "target": "esnext",
    "moduleResolution": "node16",
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true
  }
}
